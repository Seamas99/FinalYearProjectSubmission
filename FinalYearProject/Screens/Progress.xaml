<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalYearProject.Screens.Progress"
             xmlns:viewmodel="clr-namespace:FinalYearProject.ViewModels"
             xmlns:model="clr-namespace:FinalYearProject.Model"
             xmlns:screens="clr-namespace:FinalYearProject.Screens"
             xmlns:micro="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:DataType="viewmodel:ProgressViewModel"
             xmlns:controls="clr-namespace:FinalYearProject.Controls"
             xmlns:tabView="clr-namespace:Syncfusion.Maui.Toolkit.TabView;assembly=Syncfusion.Maui.Toolkit">
    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <ImageButton Source="game_icons_compass.svg" 
                     Grid.Column="1"
                     Grid.Row="1"
                     Grid.RowSpan="2"
                     Margin="0, 0, 5, 0"
                     WidthRequest="24" 
                     HeightRequest="24"
                     VerticalOptions="Center"/>

                <Label Grid.Column="2" Grid.Row="1" Text="Carbon" FontAttributes="Bold" FontSize="20" TextColor="#58C572" Margin="0,0,5,0"/>
                <Label Grid.Column="3" Grid.Row="1" Text="Compass" FontAttributes="Bold" FontSize="20" TextColor="#FFFFFF" HorizontalOptions="Start"/>
                <Label Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="2" Text="Carbon Tracking" FontAttributes="Bold" FontSize="12" TextColor="#FFFFFF" />
            </Grid>
        </Grid>
    </Shell.TitleView>

    <Grid>
        <tabView:SfTabView IndicatorBackground="#2EAA1B" IsVisible="{Binding IsContentVisible}">
            <tabView:SfTabView.Items>

                <tabView:SfTabItem Header="Carbon">
                    <tabView:SfTabItem.Content>
                        <ScrollView>
                            <VerticalStackLayout Padding="20" Spacing="15">

                                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="15">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="Carbon Footprint Trends" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                                        <micro:ChartView x:Name="carbonChartView" HeightRequest="220" Chart="{Binding MonthlyCarbonLineChart}"/>
                                    </VerticalStackLayout>
                                </Border>

                                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="15">
                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="Average Monthly Carbon" TextColor="#6B7280" FontSize="14" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding AverageCarbon}" FontAttributes="Bold" FontSize="14" TextColor="#374151" VerticalOptions="Center"/>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="#F3F4F6" />
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="{Binding CarbonHigherLower}" TextColor="#6B7280" FontSize="14" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding CarbonDifferencePercentage, StringFormat='{}{0:F0}%'}" IsVisible="{Binding CarbonDifferenceVisible}" FontAttributes="Bold" FontSize="14" TextColor="#374151" VerticalOptions="Center"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>
                        </ScrollView>
                    </tabView:SfTabItem.Content>
                </tabView:SfTabItem>

                <tabView:SfTabItem Header="XP">
                    <tabView:SfTabItem.Content>
                        <ScrollView>
                            <VerticalStackLayout Padding="20" Spacing="15">

                                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="15">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="XP Progression" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                                        <micro:ChartView x:Name="XPChartView" HeightRequest="220" Chart="{Binding MonthlyXPLineChart}"/>
                                    </VerticalStackLayout>
                                </Border>

                                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="15">
                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="Average Monthly XP" TextColor="#6B7280" FontSize="14" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding AverageXP}" FontAttributes="Bold" FontSize="14" TextColor="#374151" VerticalOptions="Center"/>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="#F3F4F6" />
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="{Binding XPHigherLower}" TextColor="#6B7280" FontSize="14" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding XPDifferencePercentage, StringFormat='{}{0:F0}%'}" FontAttributes="Bold" FontSize="14" TextColor="#374151" VerticalOptions="Center" IsVisible="{Binding XpDifferenceVisible}"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>
                        </ScrollView>
                    </tabView:SfTabItem.Content>
                </tabView:SfTabItem>

                <tabView:SfTabItem Header="Level">
                    <tabView:SfTabItem.Content>
                        <ScrollView>
                            <VerticalStackLayout Padding="20" Spacing="15">

                                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="15">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="Level History" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                                        <micro:ChartView x:Name="LevelChartView" HeightRequest="220" Chart="{Binding MonthlyLevelLineChart}"/>
                                    </VerticalStackLayout>
                                </Border>

                                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="15">
                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="Level Gain This Month" TextColor="#6B7280" FontSize="14" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding LevelGain}" FontAttributes="Bold" FontSize="14" TextColor="#374151" VerticalOptions="Center"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>
                        </ScrollView>
                    </tabView:SfTabItem.Content>
                </tabView:SfTabItem>

                <tabView:SfTabItem Header="Rank">
                    <tabView:SfTabItem.Content>
                        <ScrollView>
                            <VerticalStackLayout Padding="20" Spacing="15">

                                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="15">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="Rank Over Time" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                                        <micro:ChartView x:Name="RankChartView" HeightRequest="220" Chart="{Binding MonthlyRankLineChart}"/>
                                    </VerticalStackLayout>
                                </Border>

                                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="15">
                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="Average Rank" TextColor="#6B7280" FontSize="14" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding AverageRank}" FontAttributes="Bold" FontSize="14" TextColor="#374151" VerticalOptions="Center"/>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="#F3F4F6" />
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="Highest Rank" TextColor="#6B7280" FontSize="14" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding HighestRank}" FontAttributes="Bold" FontSize="14" TextColor="#2EAA1B" VerticalOptions="Center"/>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="#F3F4F6" />
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="Lowest Rank" TextColor="#6B7280" FontSize="14" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding LowestRank}" FontAttributes="Bold" FontSize="14" TextColor="#EF4444" VerticalOptions="Center"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>
                        </ScrollView>
                    </tabView:SfTabItem.Content>
                </tabView:SfTabItem>

                <tabView:SfTabItem Header="League">
                    <tabView:SfTabItem.Content>
                        <ScrollView>
                            <VerticalStackLayout Padding="20" Spacing="15">

                                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="15">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="League Progress" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                                        <micro:ChartView x:Name="LeagueChartView" HeightRequest="220" Chart="{Binding MonthlyLeagueNumberLineChart}"/>
                                    </VerticalStackLayout>
                                </Border>

                                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="15">
                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="Current League" TextColor="#6B7280" FontSize="14" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding CurrentLeague}" FontAttributes="Bold" FontSize="14" TextColor="#374151" VerticalOptions="Center"/>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="#F3F4F6" />
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="Highest League" TextColor="#6B7280" FontSize="14" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding HighestLeague}" FontAttributes="Bold" FontSize="14" TextColor="#2EAA1B" VerticalOptions="Center"/>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="#F3F4F6" />
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="Lowest League" TextColor="#6B7280" FontSize="14" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding LowestLeague}" FontAttributes="Bold" FontSize="14" TextColor="#EF4444" VerticalOptions="Center"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>
                        </ScrollView>
                    </tabView:SfTabItem.Content>
                </tabView:SfTabItem>

                <tabView:SfTabItem Header="Sources">
                    <tabView:SfTabItem.Content>
                        <ScrollView>
                            <VerticalStackLayout Padding="20" Spacing="15">

                                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="White" Padding="15">
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="Carbon Distribution" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                                        <micro:ChartView x:Name="CarbonSourceChartView" HeightRequest="280" Chart="{Binding MonthlyCarbonSourceDonutChart}"/>
                                    </VerticalStackLayout>
                                </Border>

                            </VerticalStackLayout>
                        </ScrollView>
                    </tabView:SfTabItem.Content>
                </tabView:SfTabItem>

            </tabView:SfTabView.Items>
        </tabView:SfTabView>
        
        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           Color="#58C572" 
                           WidthRequest="50" 
                           HeightRequest="50" />
                <Label Text="Loading..." 
               TextColor="#6B7280" 
               FontSize="16" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>