<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalYearProject.Screens.ContentViews.CalculationEntry.ShippingEntryContentView">
    <Grid>
        <ScrollView IsVisible="{Binding IsContentVisible}">
            <VerticalStackLayout Padding="20" Spacing="20">

                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding DistanceUnit, StringFormat='Distance Travelled ({0})'}" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Entry Keyboard="Numeric" 
                           Text="{Binding Distance}"
                           Placeholder="e.g. 100"
                           ClearButtonVisibility="WhileEditing"
                           BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding WeightUnit, StringFormat='Package Weight ({0})'}" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>

                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Entry Keyboard="Numeric" 
                           Text="{Binding WeightValue}"
                           Placeholder="e.g. 5.2"
                           ClearButtonVisibility="WhileEditing"
                           BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Transport Method" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Picker ItemsSource="{Binding TransportMethods}" 
                            SelectedItem="{Binding TransportMethod}"
                            Title="Select transport method..."
                            BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <Button Text="Calculate Carbon Footprint" 
                    Command="{Binding CalculateFootprintCommand}" 
                    Margin="0,15,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                   Color="#58C572" 
                   WidthRequest="50" 
                   HeightRequest="50" />
                <Label Text="Loading..." 
                       TextColor="#6B7280" 
                       FontSize="16" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentView>
