<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:FinalYearProject.ViewModels"
             x:DataType="viewmodel:FlightViewModel"
             x:Class="FinalYearProject.Screens.ContentViews.CalculationEntry.FlightEntryContentView">
    <Grid>
        <ScrollView IsVisible="{Binding IsContentVisible}">
            <VerticalStackLayout Padding="20" Spacing="20">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Passengers" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Entry Keyboard="Numeric" 
                           Text="{Binding Passengers}"
                           Placeholder="Number of passengers"
                           ClearButtonVisibility="WhileEditing"
                           BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#F9FAFB" Padding="15">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Flight Leg Details" FontSize="16" FontAttributes="Bold" TextColor="#374151" Margin="0,0,0,5"/>
                        <ContentView Content="{Binding FlightLeg}"/>
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,10">
                    <ImageButton Grid.Column="0" Source="material_menu_left.svg" Command="{Binding GoToPreviousLegCommand}" WidthRequest="44" HeightRequest="44" VerticalOptions="Center"/>

                    <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="8" VerticalOptions="Center">
                        <Button Text="Add" Command="{Binding AddFlightLegCommand}" BackgroundColor="#2EAA1B" BorderColor="#2EAA1B" BorderWidth="1" HeightRequest="40" Padding="15,0" CornerRadius="6" FontSize="12"/>
                        <Button Text="Edit" Command="{Binding EditFlightLegCommand}" BackgroundColor="#F59E0B" BorderColor="#F59E0B" BorderWidth="1" HeightRequest="40" Padding="15,0" CornerRadius="6" FontSize="12"/>
                        <Button Text="Delete" Command="{Binding DeleteFlightLegCommand}" BackgroundColor="#EF4444" BorderColor="#EF4444" BorderWidth="1" HeightRequest="40" Padding="15,0" CornerRadius="6" FontSize="12"/>
                    </HorizontalStackLayout>

                    <ImageButton Grid.Column="2" Source="material_menu_right.svg" Command="{Binding GoToNextLegCommand}" WidthRequest="44" HeightRequest="44" HorizontalOptions="End" VerticalOptions="Center"/>
                </Grid>

                <Button Text="Calculate Carbon Footprint" 
                    Command="{Binding CalculateFootprintCommand}" 
                    Margin="0,10,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                   Color="#58C572" 
                   WidthRequest="50" 
                   HeightRequest="50" />
                <Label Text="Loading..." 
                       TextColor="#6B7280" 
                       FontSize="16" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentView>
