<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalYearProject.Screens.ContentViews.SignUpContentViews.Personal">
    <Grid>
        <ScrollView IsVisible="{Binding IsContentVisible}">
            <VerticalStackLayout Padding="20" Spacing="20">

                <VerticalStackLayout Spacing="6">
                    <Label Text="First Name" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Entry Keyboard="Text" 
                           Text="{Binding FirstName}" 
                           Placeholder="e.g. Jane"
                           BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Last Name" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Entry Keyboard="Text" 
                           Text="{Binding LastName}" 
                           Placeholder="e.g. Doe"
                           BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Date of Birth" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <DatePicker Date="{Binding DateOfBirth}" BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Phone Number" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Entry Keyboard="Telephone" 
                           Text="{Binding Phone}" 
                           Placeholder="e.g. +44 7700 900077"
                           BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,15,0,0">
                    <Button Grid.Column="0" Text="Previous" Command="{Binding NavigateOrganisationCommand}" BackgroundColor="Transparent" TextColor="#6B7280" BorderColor="#D1D5DB" BorderWidth="1.5"/>
                    <Button Grid.Column="1" Text="Next" Command="{Binding NavigateLocationCommand}"/>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                   Color="#58C572" 
                   WidthRequest="50" 
                   HeightRequest="50" />
                <Label Text="Loading..." 
       TextColor="#6B7280" 
       FontSize="16" 
       FontAttributes="Bold" 
       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentView>
