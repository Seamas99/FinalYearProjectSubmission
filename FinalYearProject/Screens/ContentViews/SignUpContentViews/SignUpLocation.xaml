<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:FinalYearProject.Controls"
             x:Class="FinalYearProject.Screens.ContentViews.SignUpContentViews.SignUpLocation">
    <Grid>
        <ScrollView IsVisible="{Binding IsContentVisible}">
            <VerticalStackLayout Padding="20" Spacing="20">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Country" Style="{StaticResource SubtleLabel}"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Picker ItemsSource="{Binding Countries}" 
                            ItemDisplayBinding="{Binding name}" 
                            SelectedItem="{Binding SelectedCountry}"
                            Title="Select country..."
                            BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="State / Province / Region" Style="{StaticResource SubtleLabel}"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <controls:AutoCompleteSearchBox Placeholder="Search region..." SearchCommand="{Binding PerformRegionsSearch}" SelectedItem="{Binding Region}" DisplayMemberPath="Name" ResultsSource="{Binding SearchResults}">
                            <controls:AutoCompleteSearchBox.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding Name}" Padding="10" />
                                </DataTemplate>
                            </controls:AutoCompleteSearchBox.ItemTemplate>
                        </controls:AutoCompleteSearchBox>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Area / County" Style="{StaticResource SubtleLabel}"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <controls:AutoCompleteSearchBox Placeholder="Search area..." SearchCommand="{Binding PerformDistrictsSearch}" SelectedItem="{Binding Area}" DisplayMemberPath="Name" ResultsSource="{Binding SearchResults}">
                            <controls:AutoCompleteSearchBox.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding Name}" Padding="10" />
                                </DataTemplate>
                            </controls:AutoCompleteSearchBox.ItemTemplate>
                        </controls:AutoCompleteSearchBox>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="City" Style="{StaticResource SubtleLabel}"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <controls:AutoCompleteSearchBox Placeholder="Search city..." SearchCommand="{Binding PerformCitiesSearch}" SelectedItem="{Binding City}" DisplayMemberPath="Name" ResultsSource="{Binding SearchResults}">
                            <controls:AutoCompleteSearchBox.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding Name}" Padding="10" />
                                </DataTemplate>
                            </controls:AutoCompleteSearchBox.ItemTemplate>
                        </controls:AutoCompleteSearchBox>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Postcode / Zipcode" Style="{StaticResource SubtleLabel}"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <controls:AutoCompleteSearchBox Placeholder="Search postcode..." SearchCommand="{Binding PerformPostcodesSearch}" SelectedItem="{Binding Postcode}" DisplayMemberPath="Name" ResultsSource="{Binding SearchResults}">
                            <controls:AutoCompleteSearchBox.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding Name}" Padding="10" />
                                </DataTemplate>
                            </controls:AutoCompleteSearchBox.ItemTemplate>
                        </controls:AutoCompleteSearchBox>
                    </Border>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,15,0,0">
                    <Button Grid.Column="0" Text="Previous" Command="{Binding NavigatePersonalCommand}" BackgroundColor="Transparent" TextColor="{StaticResource CarbonGreen}" BorderColor="{StaticResource CarbonGreen}" BorderWidth="1.5"/>
                    <Button Grid.Column="1" Text="Next" Command="{Binding NavigateHouseholdCommand}"/>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                   Color="#58C572" 
                   WidthRequest="50" 
                   HeightRequest="50" />
                <Label Text="Loading..." 
       TextColor="#6B7280" 
       FontSize="16" 
       FontAttributes="Bold" 
       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentView>
