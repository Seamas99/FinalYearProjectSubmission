<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviours="clr-namespace:FinalYearProject.Controls.Behaviours"
             x:Class="FinalYearProject.Screens.ContentViews.SignUpContentViews.Household">
    <Grid>
        <ScrollView IsVisible="{Binding IsContentVisible}">
            <VerticalStackLayout Padding="20" Spacing="20">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Household Size" Style="{StaticResource SubtleLabel}"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Entry Keyboard="Numeric" Text="{Binding HouseholdSize}" BackgroundColor="Transparent">
                            <Entry.Behaviors>
                                <behaviours:EntryBehaviour Minimum="1" Maximum="99"/>
                            </Entry.Behaviors>
                        </Entry>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Home Type" Style="{StaticResource SubtleLabel}"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Picker ItemsSource="{Binding HomeTypes}" SelectedItem="{Binding HomeType}" Title="Select home type..." BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Heating Type" Style="{StaticResource SubtleLabel}"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Picker ItemsSource="{Binding HeatingTypes}" SelectedItem="{Binding HeatingType}" Title="Select heating type..." BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <Border Style="{StaticResource RoundRectangle12Border}">
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Properly insulated?" Style="{StaticResource SubtleLabel}"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding ExtraInsulation}"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E5E7EB" />
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Solar panels installed?" VerticalOptions="Center" Style="{StaticResource SubtleLabel}"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding SolarInstalled}"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E5E7EB" />
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Own a vehicle?" VerticalOptions="Center" Style="{StaticResource SubtleLabel}"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding VehicleOwnership}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="10" IsVisible="{Binding VehicleOwnership}">
                    <Label Text="Your Vehicles" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>

                    <CollectionView x:Name="SavedVehiclesCollectionView" 
                                ItemsSource="{Binding VehicleList, Mode=TwoWay}" 
                                SelectionMode="Single" 
                                SelectedItem="{Binding SelectedVehicle}" 
                                HeightRequest="150">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="15" Margin="0,0,0,8" BackgroundColor="White">
                                    <Grid ColumnDefinitions="*, *">
                                        <VerticalStackLayout Grid.Column="0">
                                            <Label Text="{Binding name}" FontAttributes="Bold" TextColor="#374151" FontSize="14"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center">
                                            <Label Text="{Binding vehicle_make, StringFormat='Make: {0}'}" TextColor="#6B7280" FontSize="12"/>
                                            <Label Text="{Binding model_name, StringFormat='Model: {0}'}" TextColor="#6B7280" FontSize="12"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="No vehicles added yet." TextColor="#9CA3AF" HorizontalOptions="Center" Margin="0,20"/>
                        </CollectionView.EmptyView>
                    </CollectionView>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Delete Selected" Command="{Binding DeleteVehicleCommand}" BackgroundColor="Transparent" TextColor="#EF4444" BorderColor="#EF4444" BorderWidth="1" HeightRequest="40" FontSize="12"/>
                        <Button Grid.Column="1" Text="Add Vehicle" Command="{Binding AddVehicleCommand}" BackgroundColor="Transparent" TextColor="#2EAA1B" BorderColor="#2EAA1B" BorderWidth="1" HeightRequest="40" FontSize="12"/>
                    </Grid>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,15,0,0">
                    <Button Grid.Column="0" Text="Previous" Command="{Binding NavigateLocationCommand}" BackgroundColor="Transparent" TextColor="{StaticResource CarbonGreen}" BorderColor="{StaticResource CarbonGreen}" BorderWidth="1.5"/>
                    <Button Grid.Column="1" Text="Next" Command="{Binding NavigatePreferencesCommand}"/>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                   Color="#58C572" 
                   WidthRequest="50" 
                   HeightRequest="50" />
                <Label Text="Loading..." 
       TextColor="#6B7280" 
       FontSize="16" 
       FontAttributes="Bold" 
       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentView>
