<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalYearProject.Screens.ContentViews.SignUpContentViews.BasicInfo">
    <Grid>
        <ScrollView IsVisible="{Binding IsContentVisible}">
            <VerticalStackLayout Padding="20" Spacing="20">

                <VerticalStackLayout Spacing="6">
                    <Label Text="Email" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Entry Keyboard="Email" 
                           Text="{Binding Email}" 
                           Placeholder="you@example.com"
                           ClearButtonVisibility="WhileEditing"
                           BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Username" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Entry Text="{Binding Username}" 
                           Placeholder="Choose a username"
                           ClearButtonVisibility="WhileEditing"
                           BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label Text="Password" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                    <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                        <Entry IsPassword="True" 
                           Text="{Binding Password}" 
                           Placeholder="Enter a strong password"
                           BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <Button Text="Next" 
                    Command="{Binding NavigateOrganisationCommand}" 
                    Margin="0,15,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                   Color="#58C572" 
                   WidthRequest="50" 
                   HeightRequest="50" />
                <Label Text="Loading..." 
                       TextColor="#6B7280" 
                       FontSize="16" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentView>
