<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalYearProject.Screens.SettingsScreen"
             xmlns:viewmodel="clr-namespace:FinalYearProject.ViewModels"
             xmlns:screens="clr-namespace:FinalYearProject.Screens"
             xmlns:model="clr-namespace:FinalYearProject.Model"
             x:DataType="viewmodel:SettingsViewModel">
    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.4*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <ImageButton Source="game_icons_compass.svg" 
                 Grid.Column="1"
                 Grid.Row="1"
                 Grid.RowSpan="2"
                 Margin="0, 0, 5, 0"
                 WidthRequest="24" 
                 HeightRequest="24"
                 VerticalOptions="Center"/>

                <Label Grid.Column="2" Grid.Row="1" Text="Carbon" FontAttributes="Bold" FontSize="20" TextColor="#58C572" Margin="0,0,5,0"/>
                <Label Grid.Column="3" Grid.Row="1" Text="Compass" FontAttributes="Bold" FontSize="20" TextColor="#FFFFFF" HorizontalOptions="Start"/>
                <Label Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="2" Text="Carbon Tracking" FontAttributes="Bold" FontSize="12" TextColor="#FFFFFF" />
            </Grid>
        </Grid>
    </Shell.TitleView>

    <Grid>
        <ScrollView IsVisible="{Binding IsContentVisible}">
            <VerticalStackLayout Padding="20" Spacing="25">

                <Border Style="{StaticResource RoundRectangle12Border}">
                    <VerticalStackLayout Spacing="20">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Distance Unit" Style="{StaticResource SubtleLabel}"/>
                            <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                                <Picker ItemsSource="{Binding DistanceUnits}" 
                                    SelectedItem="{Binding SelectedDistanceUnit}" 
                                    Title="Select distance unit..."
                                    BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Weight Unit" Style="{StaticResource SubtleLabel}"/>
                            <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                                <Picker ItemsSource="{Binding WeightUnits}" 
                                    SelectedItem="{Binding SelectedWeightUnit}" 
                                    Title="Select weight unit..."
                                    BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="App Theme" Style="{StaticResource SubtleLabel}"/>
                            <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                                <Picker ItemsSource="{Binding AppThemes}" 
                                    SelectedItem="{Binding SelectedAppTheme}" 
                                    Title="Select app theme..."
                                    BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <Button Text="Save Settings" 
                    Command="{Binding SaveSettingsCommand}" 
                    Margin="0,5,0,20"/>

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           Color="#58C572" 
                           WidthRequest="50" 
                           HeightRequest="50" />
                <Label Text="Loading..." 
               TextColor="#6B7280" 
               FontSize="16" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>