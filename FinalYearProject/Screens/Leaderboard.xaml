<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalYearProject.Screens.Leaderboard"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A2E}">
    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <ImageButton Source="game_icons_compass.svg" 
                             Grid.Column="1"
                             Grid.Row="1"
                             Grid.RowSpan="2"
                             Margin="0, 0, 5, 0"
                             WidthRequest="24" 
                             HeightRequest="24"
                             VerticalOptions="Center"/>

                <Label Grid.Column="2" Grid.Row="1" Text="Carbon" FontAttributes="Bold" FontSize="20" TextColor="#58C572" Margin="0,0,5,0"/>
                <Label Grid.Column="3" Grid.Row="1" Text="Compass" FontAttributes="Bold" FontSize="20" TextColor="#FFFFFF" HorizontalOptions="Start"/>
                <Label Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="2" Text="Carbon Tracking" FontAttributes="Bold" FontSize="12" TextColor="#FFFFFF" />
            </Grid>
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="12,12,12,0">

        <Grid ColumnDefinitions="44,*,44" RowDefinitions="Auto,Auto"
              Margin="0,0,0,8">

            <Button Text="◀"
                    FontSize="18"
                    WidthRequest="40" HeightRequest="40"
                    CornerRadius="20"
                    Padding="0"
                    VerticalOptions="Center"
                    Command="{Binding PreviousLeagueCommand}" />

            <VerticalStackLayout Grid.Column="1"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="2">
                <Label Text="{Binding CurrentLeague.LeagueName}"
                       FontSize="20" FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="{Binding CurrentLeague.ProcessedDate, StringFormat='{0:MMMM yyyy}'}"
                       FontSize="13" TextColor="Gray"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Button Text="▶"
                    FontSize="18"
                    Grid.Column="2"
                    WidthRequest="40" HeightRequest="40"
                    CornerRadius="20"
                    Padding="0"
                    VerticalOptions="Center"
                    Command="{Binding NextLeagueCommand}" />
        </Grid>

        <Picker Grid.Row="1"
                Title="Jump to month…"
                ItemsSource="{Binding MonthYearOptions}"
                SelectedItem="{Binding SelectedMonthYear}"
                Margin="0,0,0,8"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A3E}"
                TextColor="{AppThemeBinding Light=Black, Dark=White}" />

        <Grid Grid.Row="2"
              ColumnDefinitions="44,*,80,80,60"
              Padding="8,6"
              BackgroundColor="{AppThemeBinding Light=#3A7BD5, Dark=#2A5BA5}">

            <Label Text="{Binding RankHeader}"
                   FontAttributes="Bold" TextColor="White" FontSize="13"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SortByCommand}" CommandParameter="Rank"/>
                </Label.GestureRecognizers>
            </Label>

            <Label Text="{Binding UserHeader}"
                   Grid.Column="1"
                   FontAttributes="Bold" TextColor="White" FontSize="13"
                   VerticalOptions="Center" Padding="4,0,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SortByCommand}" CommandParameter="User"/>
                </Label.GestureRecognizers>
            </Label>

            <Label Text="{Binding XPHeader}"
                   Grid.Column="2"
                   FontAttributes="Bold" TextColor="White" FontSize="13"
                   HorizontalOptions="End" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SortByCommand}" CommandParameter="XP"/>
                </Label.GestureRecognizers>
            </Label>

            <Label Text="{Binding CarbonHeader}"
                   Grid.Column="3"
                   FontAttributes="Bold" TextColor="White" FontSize="13"
                   HorizontalOptions="End" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SortByCommand}" CommandParameter="Carbon"/>
                </Label.GestureRecognizers>
            </Label>

            <Label Text="{Binding LevelHeader}"
                   Grid.Column="4"
                   FontAttributes="Bold" TextColor="White" FontSize="13"
                   HorizontalOptions="End" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SortByCommand}" CommandParameter="Level"/>
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding DisplayedEntries}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="44,*,80,80,60"
                          Padding="8,10"
                          BackgroundColor="{AppThemeBinding Light=White, Dark=#252535}">

                        <Grid.Resources>
                            <Style TargetType="Label">
                                <Style.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Rank}" Value="1">
                                        <Setter Property="TextColor" Value="#000000" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding Rank}" Value="2">
                                        <Setter Property="TextColor" Value="#000000" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding Rank}" Value="3">
                                        <Setter Property="TextColor" Value="#000000" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Resources>

                        <Grid.Triggers>
                            <DataTrigger TargetType="Grid" Binding="{Binding Rank}" Value="1">
                                <Setter Property="BackgroundColor" Value="#FFD700"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Grid" Binding="{Binding Rank}" Value="2">
                                <Setter Property="BackgroundColor" Value="#C0C0C0"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Grid" Binding="{Binding Rank}" Value="3">
                                <Setter Property="BackgroundColor" Value="#CD7F32"/>
                            </DataTrigger>
                        </Grid.Triggers>

                        <Label Text="{Binding Rank}"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>

                        <Label Text="{Binding Username}"
                               Grid.Column="1"
                               VerticalOptions="Center"
                               Padding="4,0,0,0"
                               LineBreakMode="TailTruncation"/>

                        <Label Text="{Binding MonthXP}"
                               Grid.Column="2"
                               HorizontalOptions="End"
                               VerticalOptions="Center"/>

                        <Label Text="{Binding MonthCarbon, StringFormat='{0:F1}'}"
                               Grid.Column="3"
                               HorizontalOptions="End"
                               VerticalOptions="Center"/>

                        <Label Text="{Binding Level}"
                               Grid.Column="4"
                               HorizontalOptions="End"
                               VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.RowSpan="4"
              IsVisible="{Binding IsBusy}"
              BackgroundColor="#80000000">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" WidthRequest="48" HeightRequest="48"/>
                <Label Text="Loading leagues…" TextColor="White" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>