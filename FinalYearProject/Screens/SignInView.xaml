<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalYearProject.Screens.SignInView">
    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.4*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <ImageButton Source="game_icons_compass.svg" 
                             Grid.Column="1"
                             Grid.Row="1"
                             Grid.RowSpan="2"
                             Margin="0, 0, 5, 0"
                             WidthRequest="24" 
                             HeightRequest="24"
                             VerticalOptions="Center"/>

                <Label Grid.Column="2" Grid.Row="1" Text="Carbon" FontAttributes="Bold" FontSize="20" TextColor="#58C572" Margin="0,0,5,0"/>
                <Label Grid.Column="3" Grid.Row="1" Text="Compass" FontAttributes="Bold" FontSize="20" TextColor="#FFFFFF" HorizontalOptions="Start"/>
                <Label Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="2" Text="Carbon Tracking" FontAttributes="Bold" FontSize="12" TextColor="#FFFFFF" />
            </Grid>
        </Grid>
    </Shell.TitleView>
    <Grid>
        <ScrollView IsVisible="{Binding IsContentVisible}">
            <VerticalStackLayout Padding="20" Spacing="25" VerticalOptions="Center">

                <VerticalStackLayout Spacing="5" HorizontalOptions="Center" Margin="0,0,0,10">
                    <Label Text="Welcome Back" FontSize="28" FontAttributes="Bold" TextColor="#111827" HorizontalOptions="Center"/>
                    <Label Text="Sign in to continue tracking your carbon footprint." FontSize="14" TextColor="#6B7280" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <Border Stroke="#E5E7EB" 
                    StrokeThickness="1" 
                    StrokeShape="RoundRectangle 16" 
                    BackgroundColor="White" 
                    Padding="20, 30">
                    <VerticalStackLayout Spacing="20">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Email Address" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                            <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                                <Entry Text="{Binding Email}" 
                                   Keyboard="Email"
                                   Placeholder="you@example.com"
                                   ClearButtonVisibility="WhileEditing"
                                   BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Password" FontSize="14" TextColor="#6B7280" FontAttributes="Bold"/>
                            <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="10,0">
                                <Entry IsPassword="True" 
                                   Text="{Binding Password}" 
                                   Placeholder="Enter your password"
                                   BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="12" Margin="0,15,0,0">

                            <Button Text="Sign In" 
                                Command="{Binding SignInCommand}" />

                            <Grid ColumnDefinitions="*, Auto, *" Margin="0,10" VerticalOptions="Center">
                                <BoxView Grid.Column="0" HeightRequest="1" Color="#E5E7EB" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="OR" TextColor="#9CA3AF" FontSize="12" Margin="10,0" VerticalOptions="Center"/>
                                <BoxView Grid.Column="2" HeightRequest="1" Color="#E5E7EB" VerticalOptions="Center"/>
                            </Grid>

                            <Button Text="Create an account" 
                                Command="{Binding NavigateSignUpCommand}" 
                                BackgroundColor="Transparent" 
                                TextColor="#2EAA1B" 
                                BorderColor="#2EAA1B"
                                BorderWidth="1.5"/>

                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           Color="#58C572" 
                           WidthRequest="50" 
                           HeightRequest="50" />
                <Label Text="Loading..." 
               TextColor="#6B7280" 
               FontSize="16" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>