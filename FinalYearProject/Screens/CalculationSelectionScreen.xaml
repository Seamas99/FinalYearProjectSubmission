<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalYearProject.Screens.CalculationSelectionScreen"
             xmlns:controls="clr-namespace:FinalYearProject.Controls"
             xmlns:viewmodel="clr-namespace:FinalYearProject.ViewModels"
             xmlns:model="clr-namespace:FinalYearProject.Model"
             xmlns:screens="clr-namespace:FinalYearProject.Screens"
             x:DataType="viewmodel:CreateEstimateViewModel"
             Shell.TabBarIsVisible="true"
             Title="CalculationSelectionScreen">
    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.4*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <ImageButton Source="game_icons_compass.svg" 
                         Grid.Column="1"
                         Grid.Row="1"
                         Grid.RowSpan="2"
                         Margin="0, 0, 5, 0"
                         WidthRequest="24" 
                         HeightRequest="24"
                         VerticalOptions="Center"/>

                <Label Grid.Column="2" Grid.Row="1" Text="Carbon" FontAttributes="Bold" FontSize="20" TextColor="#58C572" Margin="0,0,5,0"/>
                <Label Grid.Column="3" Grid.Row="1" Text="Compass" FontAttributes="Bold" FontSize="20" TextColor="#FFFFFF" HorizontalOptions="Start"/>
                <Label Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="2" Text="Carbon Tracking" FontAttributes="Bold" FontSize="12" TextColor="#FFFFFF" />
            </Grid>
        </Grid>
    </Shell.TitleView>
    <Grid>
        <Grid Margin="0" ColumnDefinitions="*" RowDefinitions="*, *, *, *" IsVisible="{Binding IsContentVisible}">

            <Border Grid.Row="0" 
                Margin="20" 
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectVehicleCommand}" />
                </Border.GestureRecognizers>
                <Grid>
                    <Image Source="vehicles_card.png" Aspect="AspectFill"/>
                    <VerticalStackLayout VerticalOptions="Center" 
                                     HorizontalOptions="Start" 
                                     Padding="20">
                        <Label Text="Vehicles" 
                           TextColor="White" 
                           FontSize="24" 
                           FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Grid.Row="1" 
                Margin="20" 
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectElectricityCommand}" />
                </Border.GestureRecognizers>
                <Grid>
                    <Image Source="electricity_card.png" Aspect="AspectFill"/>
                    <VerticalStackLayout VerticalOptions="Center" 
                                     HorizontalOptions="Start" 
                                     Padding="20">
                        <Label Text="Electricity" 
                           TextColor="White" 
                           FontSize="24"
                           FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Grid.Row="2" 
                Margin="20" 
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectFlightCommand}" />
                </Border.GestureRecognizers>
                <Grid>
                    <Image Source="flying_card.png" Aspect="AspectFill"/>
                    <VerticalStackLayout VerticalOptions="Center" 
                                     HorizontalOptions="Start" 
                                     Padding="20">
                        <Label Text="Flying" 
                           TextColor="White" 
                           FontSize="24"
                           FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Grid.Row="3" 
                Margin="20" 
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectShippingCommand}" />
                </Border.GestureRecognizers>
                <Grid>
                    <Image Source="shipping_card.png" Aspect="AspectFill"/>
                    <VerticalStackLayout VerticalOptions="Center" 
                                     HorizontalOptions="Start" 
                                     Padding="20">
                        <Label Text="Shipping" 
                           TextColor="White" 
                           FontSize="24"
                           FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

        </Grid>

        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           Color="#58C572" 
                           WidthRequest="50" 
                           HeightRequest="50" />
                <Label Text="Loading..." 
               TextColor="#6B7280" 
               FontSize="16" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>