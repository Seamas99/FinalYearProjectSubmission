<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalYearProject.Screens.Challenges">
    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <ImageButton Source="game_icons_compass.svg" 
                             Grid.Column="1"
                             Grid.Row="1"
                             Grid.RowSpan="2"
                             Margin="0, 0, 5, 0"
                             WidthRequest="24" 
                             HeightRequest="24"
                             VerticalOptions="Center"/>

                <Label Grid.Column="2" Grid.Row="1" Text="Carbon" FontAttributes="Bold" FontSize="20" TextColor="#58C572" Margin="0,0,5,0"/>
                <Label Grid.Column="3" Grid.Row="1" Text="Compass" FontAttributes="Bold" FontSize="20" TextColor="#FFFFFF" HorizontalOptions="Start"/>
                <Label Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="2" Text="Carbon Tracking" FontAttributes="Bold" FontSize="12" TextColor="#FFFFFF" />
            </Grid>
        </Grid>
    </Shell.TitleView>

    <Grid>
        <ScrollView IsVisible="{Binding IsContentVisible}">
            <VerticalStackLayout Padding="20" Spacing="25">

                <!-- Uncompleted Challenges -->
                <Label Text="Uncompleted Challenges" Style="{StaticResource BigTitle}"/>

                <CollectionView ItemsSource="{Binding UncompletedChallenges}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="15" Margin="0,5">
                                <VerticalStackLayout Spacing="5">

                                    <Label Text="{Binding Title}"
                                       FontSize="18"
                                       FontAttributes="Bold"/>

                                    <Label Text="{Binding Description}"
                                       FontSize="14"
                                       TextColor="Gray"/>

                                    <Label Text="XP Reward:"
                                       FontAttributes="Bold"/>
                                    <Label Text="{Binding XPReward}" />

                                    <Label Text="Reward"
                                       FontAttributes="Bold"
                                       IsVisible="{Binding HasReward}"/>
                                    <Label Text="{Binding Reward}" 
                                       IsVisible="{Binding HasReward}"/>

                                    <Button Text="Accept Challenge"
                                        Command="{Binding BindingContext.AcceptChallengeCommand, Source={x:Reference Challenges}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding ChallengeAccepted, Converter={StaticResource InverseBoolConverter}}"/>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Completed Challenges -->
                <Label Text="Completed Challenges" Style="{StaticResource BigTitle}"/>

                <CollectionView ItemsSource="{Binding CompletedChallenges}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="15" Margin="0,5" BackgroundColor="#e8f5e9">
                                <VerticalStackLayout Spacing="5">

                                    <Label Text="{Binding Title}"
                                       FontSize="18"
                                       FontAttributes="Bold"/>

                                    <Label Text="{Binding Description}"
                                       FontSize="14"
                                       TextColor="Gray"/>

                                    <Label Text="Completed ✔"
                                       TextColor="Green"
                                       FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           Color="#58C572" 
                           WidthRequest="50" 
                           HeightRequest="50" />
                <Label Text="Loading..." 
               TextColor="#6B7280" 
               FontSize="16" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
