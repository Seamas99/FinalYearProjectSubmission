<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalYearProject.Controls.AutoCompleteSearchBox"
             x:Name="this">
    <VerticalStackLayout>
        <!--<SearchBar x:Name="InternalSearchBar"
                   Placeholder="{Binding Placeholder, Source={x:Reference this}}"
                   TextChanged="OnTextChanged" />-->



        <Entry x:Name="InternalSearchBar"
                   Placeholder="{Binding Placeholder, Source={x:Reference this}}"
                   VerticalOptions="Center"
                   TextColor="Black"
                   PlaceholderColor="Gray"
                   FontSize="16"
                   TextChanged="OnTextChanged"
                   ClearButtonVisibility="WhileEditing" />

        <Border IsVisible="{Binding IsDropdownOpen, Source={x:Reference this}}"
                ZIndex="10" 
                BackgroundColor="White"
                MaximumHeightRequest="300">
            <CollectionView ItemsSource="{Binding ResultsSource, Source={x:Reference this}}"
                            ItemTemplate="{Binding ItemTemplate, Source={x:Reference this}}"
                            SelectionMode="Single"
                            SelectionChanged="OnSelectionChanged" />
        </Border>
    </VerticalStackLayout>
</ContentView>
