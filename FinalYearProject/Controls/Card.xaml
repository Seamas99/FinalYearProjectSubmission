<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="Root"
             x:Class="FinalYearProject.Controls.Card">

    <VerticalStackLayout BackgroundColor="Transparent">
        <Border Background="{Binding Background, Source={x:Reference Root}}"
                Padding="{Binding Padding, Source={x:Reference Root}}"
                StrokeShape="{Binding CornerRadius, Source={x:Reference Root}, Converter={StaticResource CornerRadiusConverter}}">

            <Border.GestureRecognizers>
                <TapGestureRecognizer 
                    Command="{Binding Command, Source={x:Reference Root}}" 
                    CommandParameter="{Binding CommandParameter, Source={x:Reference Root}}"/>
            </Border.GestureRecognizers>

            <Label Text="{Binding Text, Source={x:Reference Root}}" 
                   InputTransparent="True" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center" 
                   FontSize="{Binding FontSize, Source={x:Reference Root}}" 
                   TextColor="{Binding FontColour, Source={x:Reference Root}}"/>
        </Border>
    </VerticalStackLayout>
</ContentView>