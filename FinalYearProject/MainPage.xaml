<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinalYearProject.MainPage"
             xmlns:viewmodel="clr-namespace:FinalYearProject.ViewModels"
             xmlns:model="clr-namespace:FinalYearProject.Model"
             xmlns:screens="clr-namespace:FinalYearProject.Screens"
             xmlns:micro="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="viewmodel:MainViewModel"
             xmlns:controls="clr-namespace:FinalYearProject.Controls"
             Title="{Binding Title}">

    <!--<ContentPage.ToolbarItems>
        <ToolbarItem Text="Profile" IconImageSource="material_account.svg" Command="{Binding GoToProfilePageCommand}" />
        <ToolbarItem Text="Notifications" IconImageSource="material_bell.svg" Command="{Binding GoToAlertPageCommand}"/>
    </ContentPage.ToolbarItems>-->

    <Shell.TitleView>
        <Grid HorizontalOptions="Fill" Padding="0,0,15,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ImageButton Source="material_account.svg" 
                         Grid.Column="0"
                         Command="{Binding GoToProfilePageCommand}"
                         WidthRequest="24" 
                         HeightRequest="24"
                         VerticalOptions="Center" />

            <Grid Grid.Column="1" HorizontalOptions="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <ImageButton Source="game_icons_compass.svg" 
                             Grid.Column="0"
                             Grid.Row="1"
                             Grid.RowSpan="2"
                             Margin="0, 0, 10, 0"
                             WidthRequest="24" 
                             HeightRequest="24"
                             VerticalOptions="Center"/>

                <Label Grid.Column="1" Grid.Row="1" Text="Carbon" FontAttributes="Bold" FontSize="20" TextColor="#58C572" Margin="0,0,5,0"/>
                <Label Grid.Column="2" Grid.Row="1" Text="Compass" FontAttributes="Bold" FontSize="20" TextColor="#FFFFFF" HorizontalOptions="Start"/>
                <Label Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" Text="Carbon Tracking" FontAttributes="Bold" FontSize="12" TextColor="#FFFFFF" />

            </Grid>

            <ImageButton Source="material_bell.svg" 
                         Grid.Column="2"
                         Command="{Binding GoToAlertPageCommand}"
                         WidthRequest="24" 
                         HeightRequest="24"
                         VerticalOptions="Center" />

        </Grid>
    </Shell.TitleView>

    <Grid>
        <ScrollView IsVisible="{Binding IsContentVisible}">
            <VerticalStackLayout Padding="20" Spacing="25">

                <VerticalStackLayout Spacing="5">
                    <Label Text="{Binding Username, StringFormat='Welcome Back, {0}!'}" FontSize="28" FontAttributes="Bold" TextColor="#111827"/>
                    <Label Text="Here is your carbon snapshot for this month." FontSize="14" TextColor="#6B7280"/>
                </VerticalStackLayout>

                <Border Stroke="#E5E7EB" StrokeThickness="1" StrokeShape="RoundRectangle 16" BackgroundColor="White" Padding="20">
                    <VerticalStackLayout Spacing="15">

                        <Label Text="Monthly Sources" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>

                        <micro:ChartView x:Name="chartView" HeightRequest="250" Chart="{Binding MonthlyCarbonSourceDonutChart}"/>

                        <BoxView HeightRequest="1" Color="#F3F4F6"/>

                        <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                            <Label Grid.Column="0" Text="Top Carbon Source:" TextColor="#6B7280" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding BiggestCarbonSource}" TextColor="#EF4444" FontAttributes="Bold" FontSize="14" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <Button Text="Add a carbon activity" 
                    Command="{Binding GoToFootprintSelectionCommand}" 
                    Margin="0,10,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                   Color="#58C572" 
                                   WidthRequest="50" 
                                   HeightRequest="50" />
                <Label Text="Loading..." 
                       TextColor="#6B7280" 
                       FontSize="16" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
